{
  "manifest_version": 3,
  "name": "Clipper",
  "version": "1.4.2",
  "description": "Извлекает контент страницы и конвертирует в Markdown",
  "permissions": ["activeTab", "downloads", "clipboardWrite", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
